<UserControl x:Class="ChuniPet.Views.OriginPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="230" d:DesignWidth="510">

    <Grid Margin="8,8,8,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- search box -->
            <RowDefinition Height="*" />      <!-- list -->
            <RowDefinition Height="Auto" />   <!-- back button -->
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Cursor="Hand"
              Margin="0,-30,0,4">
            <Image Source="/Assets/Images/honor_bg_rainbow.png"
                   Stretch="Fill" />

            <TextBox x:Name="SearchBox"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="13"
                     Padding="8,5"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged">
                <TextBox.Resources>
                    <!-- Placeholder text -->
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Search copied items..."
                                                           Foreground="Black"
                                                           FontSize="23"
                                                           Margin="8,0,0,0" />
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Cursor="Hand"
                              Margin="0,0,0,4"
                              MouseLeftButtonUp="HistoryItem_Hold"
                              MouseLeftButtonDown="HistoryItem_Click">
                            <Image x:Name="HistoryItem"
                                   Source="/Assets/Images/honor_bg_gold.png"
                                   Stretch="Fill" />

                            <Grid Margin="8,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding}"
                                           TextAlignment="Center"
                                           Foreground="Black"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           MaxWidth="380" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2"
                Style="{StaticResource ImageButtonStyle}"
                Click="BackButton_Click"
                HorizontalAlignment="Left"
                Margin="0,6,0,0">
            <Image Source="/Assets/Images/link_level_01.png" Width="40" Height="40" />
        </Button>
    </Grid>
</UserControl>